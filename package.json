{
  "name": "dev-containers-oss",
  "displayName": "Dev Containers OSS",
  "version": "1.0.0",
  "description": "Extension for building and running a dev container",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-h-a-d-o-w/dev-containers-oss.git"
  },
  "publisher": "s-h-a-d-o-w",
  "main": "./dist/extension.js",
  "scripts": {
    "e2e": "playwright test",
    "dev": "node esbuild.mts --watch",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "build": "node esbuild.mts --production",
    "package": "pnpm build && vsce package --no-dependencies",
    "prepare": "husky",
    "knip": "knip"
  },
  "dependencies": {
    "@devcontainers/cli": "^0.87.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@s-h-a-d-o-w/oxlint-config": "^1.1.2",
    "@types/node": "^24.13.3",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "knip": "^6.29.0",
    "ky": "^2.0.2",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "dev-containers-oss.openFolderInDevcontainer",
        "title": "Reopen Folder in Container",
        "category": "Dev Containers"
      },
      {
        "command": "dev-containers-oss.openDevcontainerConfig",
        "title": "Open Container Configuration File",
        "category": "Dev Containers"
      },
      {
        "command": "dev-containers-oss.rebuildAndOpen",
        "title": "Rebuild and Reopen in Container",
        "category": "Dev Containers"
      },
      {
        "command": "dev-containers-oss.reopenFolderLocally",
        "title": "Reopen Folder Locally",
        "category": "Dev Containers"
      },
      {
        "command": "dev-containers-oss.resetReopenPrompt",
        "title": "Reset Reopen Prompt",
        "category": "Dev Containers"
      }
    ],
    "configuration": {
      "title": "Dev Containers OSS",
      "properties": {
        "dev-containers-oss.forwardSshAgent": {
          "type": "boolean",
          "default": true,
          "description": "Forward the local SSH agent to the devcontainer (adds 'ForwardAgent yes' to the generated ~/.ssh/config host block), so your local keys are usable inside the container."
        },
        "dev-containers-oss.copyKnownHosts": {
          "type": "boolean",
          "default": true,
          "description": "Copy the host's ~/.ssh/known_hosts into the devcontainer, so SSH connections (e.g. git over SSH) don't prompt to verify host authenticity."
        },
        "dev-containers-oss.copyGitConfig": {
          "type": "boolean",
          "default": true,
          "description": "Copy the host's ~/.gitconfig into the devcontainer, so git inside the container uses the same identity (user.name/email) and settings as the host."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "dev-containers-oss.openDevcontainerConfig"
        },
        {
          "command": "dev-containers-oss.openFolderInDevcontainer"
        },
        {
          "command": "dev-containers-oss.rebuildAndOpen"
        }
      ],
      "statusBar/remoteIndicator": [
        {
          "command": "dev-containers-oss.openDevcontainerConfig",
          "group": "remote_30_devcontainer_3local@1",
          "when": "dev-containers-oss.hasConfig"
        },
        {
          "command": "dev-containers-oss.openFolderInDevcontainer",
          "group": "remote_30_devcontainer_3local@2",
          "when": "!remoteName && dev-containers-oss.hasConfig"
        },
        {
          "command": "dev-containers-oss.rebuildAndOpen",
          "group": "remote_30_devcontainer_3local@3",
          "when": "dev-containers-oss.hasConfig"
        },
        {
          "command": "dev-containers-oss.reopenFolderLocally",
          "group": "remote_30_devcontainer_3local@4",
          "when": "remoteName"
        }
      ]
    }
  },
  "activationEvents": [
    "onResolveRemoteAuthority:dev-containers-oss",
    "onStartupFinished",
    "workspaceContains:.devcontainer/devcontainer.json"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "enabledApiProposals": [
    "resolvers"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "containers",
    "devcontainer",
    "docker"
  ],
  "files": [
    "assets/icon.png",
    "dist/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
